# ── Service identity (assigned from the dashboard after registration) ──
# Copy these from the callout shown after clicking "Register Service"
SERVICE_NAME=        # e.g. s2
VITE_BASE_PATH=      # e.g. /s2  (same as path prefix)
DB_SCHEMA=           # e.g. schema_s2

# ── Service config ─────────────────────────────────────────
PORT=3000

# ── Database (local dev only) ───────────────────────────────
# In production, DB_USER and DB_PASSWORD are auto-provisioned by the dashboard
# when you activate your service — a dedicated DB user is created for your schema.
# For local dev, use any credentials that match your docker-compose.yml.
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=rmsb_db

DB_HOST=postgres
DB_PORT=5432
DB_NAME=rmsb_db
DB_USER=admin          # overridden in production by the dashboard
DB_PASSWORD=password   # overridden in production by the dashboard
