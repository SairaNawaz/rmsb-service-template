# ── Service identity ────────────────────────────────────────────────────────
SERVICE_NAME=s2          # e.g. s2, s3 — used to derive all values below

# ── Local DB config ──────────────────────────────────────────────────────────
# Convention: replace s2 with your SERVICE_NAME in all values below
POSTGRES_USER=s2_user
POSTGRES_PASSWORD=s2_pass
POSTGRES_DB=s2_db

DB_HOST=postgres
DB_PORT=5432
DB_NAME=s2_db
DB_USER=s2_user
DB_PASSWORD=s2_pass

# ── Production ───────────────────────────────────────────────────────────────
# DB_USER and DB_PASSWORD are auto-provisioned by the dashboard on activation.
# GHCR_OWNER is set as a global Jenkins var — not needed here.
