# ── Service identity (assigned from the dashboard after registration) ──
SERVICE_NAME=        # e.g. s2
GHCR_OWNER=          # e.g. kloudius
# VITE_BASE_PATH and DB_SCHEMA are derived automatically from SERVICE_NAME

# ── Service config ──────────────────────────────────────────────────────
PORT=3000

# ── Database (local dev only) ───────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=rmsb_db

DB_HOST=postgres
DB_PORT=5432
DB_NAME=rmsb_db
DB_USER=admin
DB_PASSWORD=password
